# InsiteIQ v1 Foundation — Environment template
# Copy to .env and fill real values. .env is gitignored, never commit.

# --- App ---
APP_NAME=InsiteIQ
APP_ENV=development
DEBUG=true

# --- MongoDB ---
# Container-internal hostname inside docker-compose network
MONGO_URL=mongodb://mongo:27017
MONGO_DB=insiteiq
MONGO_INITDB_DATABASE=insiteiq

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-GENERATE-64-CHARS-SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7
