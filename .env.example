# InsiteIQ Environment Variables
# Copy to .env and adjust values

# App
APP_NAME=InsiteIQ
DEBUG=false
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb://mongo:27017
MONGO_DB=insiteiq
MONGO_INITDB_DATABASE=insiteiq

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Admin seed
ADMIN_EMAIL=admin@insiteiq.io
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# API
API_HOST=0.0.0.0
API_PORT=8000
