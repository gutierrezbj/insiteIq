{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "InsiteIQ Frontend (Vite)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/vite", "--port", "5273", "--strictPort"],
      "port": 5273,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "InsiteIQ API (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--reload"],
      "port": 8000,
      "autoPort": true,
      "cwd": "backend"
    }
  ]
}
